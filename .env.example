# IP LAN de la machine (Wi-Fi) — ipconfig, carte "Wi-Fi" / "Ethernet"
# 192.168.125.1 = souvent Docker Desktop ; pour un autre PC, preferer l'IP Wi-Fi (ex. 192.168.12.101)
LAN_HOST=192.168.12.101

# Navigateur : localhost/LAN → même hôte:8000 ; tunnel HTTPS → URL backend (voir docs/ACCES-INTERNET-CLOUDFLARE.md)
NEXT_PUBLIC_GRAPHQL_ENDPOINT=http://localhost:8000/graphql
NEXT_PUBLIC_MERCURE_HUB_URL=http://127.0.0.1:8080/.well-known/mercure

# Serveur Next.js (SSR dans Docker) — joindre le backend sur l'hôte
GRAPHQL_ENDPOINT=http://host.docker.internal:8000/graphql

# Déploiement Docker Compose (docker-compose.staging.yml)
# Tag publié par la CI : main, develop, ou le SHA du commit (pas "latest")
IMAGE_REF=ghcr.io/<owner>/oct-frontend:main
FRONTEND_PORT=3000
